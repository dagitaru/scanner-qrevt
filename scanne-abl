<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Scanner Panitia Event</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/html5-qrcode"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap');
    body { font-family: 'Inter', sans-serif; background-color: #111827; color: white; }
    #reader { width: 100%; max-width: 500px; margin: 0 auto; border-radius: 12px; overflow: hidden; border: 2px solid #374151; }
    #reader video { object-fit: cover; border-radius: 12px; }
  </style>
</head>
<body class="min-h-screen flex flex-col">

  <header class="bg-gray-900 border-b border-gray-800 p-4 text-center sticky top-0 z-10">
    <h1 class="text-xl font-bold text-indigo-400">Scanner Panitia</h1>
    <p class="text-xs text-gray-400 mt-1">Arahkan kamera ke QR Code Peserta</p>
  </header>

  <main class="flex-grow p-4 flex flex-col items-center justify-center">
    
    <div id="reader" class="shadow-2xl shadow-indigo-900/20 bg-gray-800 relative"></div>
    
    <div class="mt-6 w-full max-w-md bg-gray-800 rounded-xl p-4 border border-gray-700">
      <h3 class="text-sm font-semibold text-gray-300 mb-2">Input Manual (Jika kamera gagal):</h3>
      <div class="flex gap-2">
        <input type="text" id="manualTicketInput" placeholder="Contoh: ABL-260715-123-001" 
               class="flex-grow px-4 py-3 rounded-lg bg-gray-900 border border-gray-700 text-white focus:outline-none focus:border-indigo-500 uppercase">
        <button onclick="processManualInput()" class="bg-indigo-600 hover:bg-indigo-700 px-6 font-bold rounded-lg transition-colors">
          CEK
        </button>
      </div>
    </div>
  </main>

  <script>
    // ==========================================
    // MASUKKAN URL WEB APP GOOGLE SCRIPT ANDA DI SINI
    // ==========================================
    const GAS_API_URL = "https://script.google.com/macros/s/AKfycbz3UQf1gMs_7BmiPDu6uaL2h2Hi8kdXUhhQX4dgYBuSlzqCW-w46im-cT26AsouGNQz/exec";

    let html5QrcodeScanner;
    let isProcessing = false;

    // Fungsi membuat suara BEEP
    function playBeep() {
      const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      const oscillator = audioCtx.createOscillator();
      const gainNode = audioCtx.createGain();
      oscillator.connect(gainNode);
      gainNode.connect(audioCtx.destination);
      oscillator.type = 'sine';
      oscillator.frequency.setValueAtTime(800, audioCtx.currentTime);
      gainNode.gain.setValueAtTime(0.1, audioCtx.currentTime);
      oscillator.start();
      oscillator.stop(audioCtx.currentTime + 0.1);
    }

    // Fungsi Memproses Tiket ke Backend
    async function processTicket(ticketId) {
      if (isProcessing) return;
      isProcessing = true;
      playBeep();
      
      if(html5QrcodeScanner) html5QrcodeScanner.pause(true); // Pause kamera agar tidak dobel scan

      Swal.fire({
        title: 'Memverifikasi...',
        text: 'Menghubungi database tiket.',
        allowOutsideClick: false,
        didOpen: () => { Swal.showLoading(); }
      });

      try {
        const response = await fetch(`${GAS_API_URL}?action=scan&ticketId=${ticketId}`, {
          method: 'GET'
        });
        const result = await response.json();

        if (result.success) {
          Swal.fire({
            icon: 'success',
            title: 'AKSES DITERIMA',
            html: `<div class="text-lg"><strong>${result.nama}</strong><br/><span class="text-sm text-gray-500">${ticketId}</span></div>`,
            confirmButtonColor: '#4f46e5',
            confirmButtonText: 'Scan Berikutnya'
          }).then(() => { resumeScanner(); });
        } else {
          Swal.fire({
            icon: 'error',
            title: 'AKSES DITOLAK!',
            html: `<div class="text-lg text-red-600 font-bold">${result.message}</div>
                   <div class="mt-2 text-gray-700">Nama: ${result.nama}</div>`,
            confirmButtonColor: '#ef4444',
            confirmButtonText: 'Tutup'
          }).then(() => { resumeScanner(); });
        }
      } catch (error) {
        Swal.fire({
          icon: 'warning',
          title: 'Koneksi Gagal',
          text: 'Pastikan internet panitia stabil, lalu coba lagi.',
          confirmButtonText: 'Tutup'
        }).then(() => { resumeScanner(); });
      }
    }

    function resumeScanner() {
      isProcessing = false;
      document.getElementById('manualTicketInput').value = '';
      if(html5QrcodeScanner) html5QrcodeScanner.resume();
    }

    function processManualInput() {
      const input = document.getElementById('manualTicketInput').value.trim();
      if(input) { processTicket(input); }
    }

    // Inisialisasi Scanner Kamera
    function onScanSuccess(decodedText) {
      processTicket(decodedText.trim());
    }

    window.onload = () => {
      html5QrcodeScanner = new Html5QrcodeScanner(
        "reader", { fps: 10, qrbox: { width: 250, height: 250 }, aspectRatio: 1.0 }
      );
      html5QrcodeScanner.render(onScanSuccess);
    };
  </script>
</body>
</html>
